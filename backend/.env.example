# AI Provider
# auto = Ollama (local) by default; or set ollama | gemini | anthropic
AI_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=llama3:latest
# For Anthropic Claude: Use ANTHROPIC_API_KEY
# For Google Gemini: Use GEMINI_API_KEY
ANTHROPIC_API_KEY=sk-ant-your-key-here
GEMINI_API_KEY=your-gemini-key-here

# JWT Authentication
# Generate a secure secret: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=your-secure-random-secret-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Database
DATABASE_URL=./iqt.db

# CORS Settings (frontend URLs)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Alpaca API (legacy — app uses IBKR for trading)
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_DATA_URL=https://data.alpaca.markets

# Interactive Brokers (IB Gateway / TWS — required for execution, portfolio, options)
IBKR_HOST=127.0.0.1
IBKR_PORT=4002
IBKR_CLIENT_ID=10
IBKR_ACCOUNT=

# Logging
LOG_LEVEL=INFO

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# LEAN local backtests (Mac: Docker Desktop + ./scripts/setup-lean-mac.sh)
LEAN_WORKSPACE_DIR=./lean_workspace
LEAN_CLI_PATH=
LEAN_BACKTEST_TIMEOUT_SECONDS=900
